generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PomodoroType {
  FOCUS
  SHORT_BREAK
  LONG_BREAK
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  boards           Board[]
  tasks            Task[]
  pomodoroSessions PomodoroSession[]
  timeEntries      TimeEntry[]
}

model Board {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  columns Column[]

  @@index([userId])
}

model Column {
  id        String   @id @default(cuid())
  title     String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@index([boardId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  position    Int
  priority    Priority  @default(MEDIUM)
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  columnId String
  column   Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  timeEntries      TimeEntry[]
  pomodoroSessions PomodoroSession[]

  @@index([columnId])
  @@index([userId])
}

model PomodoroSession {
  id        String       @id @default(cuid())
  type      PomodoroType @default(FOCUS)
  duration  Int
  startedAt DateTime     @default(now())
  endedAt   DateTime?
  completed Boolean      @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([taskId])
}

model TimeEntry {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationSeconds Int       @default(0)
  note            String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([taskId])
}
